Package: DFATools
Title: Discriminant Function Analysis for Multivariate Classification
Version: 0.0.0.9000
Authors@R: 
    c(
      person("Prabhani", "Athukorala", email = "pha268@my.utexas.edu", role = c("aut", "cre")),
